# Environment & secrets
*.env/
.env
.env.*

# Python bytecode
*.pyc
*.pyo
__pycache__/

# Virtual environments
.venv/
venv/
env/

# Package metadata (generated by pip install -e .)
*.egg-info/

# UV
uv.lock
.python-version

# IDE
.vscode/
!.vscode/settings.json
.idea/

# Cluster / pipeline state directory (generated on the remote node)
.chain_state/

# Data & experiments (runtime artifacts — NOT configs which are tracked)
data/
experiments/checkpoints/
experiments/logs/
experiments/figures/
experiments/results/

# Unsloth compiled cache (auto-generated, must be cleared after version changes)
unsloth_compiled_cache/
